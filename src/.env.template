# Environment Configuration Template
# Copy this file as .env.local and fill in actual values
# DO NOT commit this file to version control

# ===========================
# DEVELOPMENT ENVIRONMENT
# ===========================
DEV_DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=ShieldReportDb;Username=postgres;Password=postgres
DEV_JWT_SECRET_KEY=your-super-secret-key-must-be-at-least-32-characters-long
DEV_JWT_ISSUER=ShieldReport
DEV_JWT_AUDIENCE=ShieldReport.Client
DEV_SMTP_HOST=smtp.mailserver.local
DEV_SMTP_PORT=587
DEV_SMTP_USERNAME=smtp-user
DEV_SMTP_PASSWORD=smtp-password
DEV_SMTP_FROM_ADDRESS=no-reply@dev.project.local

# ===========================
# STAGING ENVIRONMENT
# ===========================
STAGING_DB_CONNECTION_STRING=Host=staging-db.internal;Port=5432;Database=ShieldReportDbStaging;Username=postgres;Password=staging-password
STAGING_JWT_SECRET_KEY=staging-super-secret-key-must-be-at-least-32-characters-long
STAGING_JWT_ISSUER=ShieldReport
STAGING_JWT_AUDIENCE=ShieldReport.Client
STAGING_SMTP_HOST=smtp.mailserver.staging
STAGING_SMTP_PORT=587
STAGING_SMTP_USERNAME=staging-smtp-user
STAGING_SMTP_PASSWORD=staging-smtp-password
STAGING_SMTP_FROM_ADDRESS=no-reply@staging.project.local

# ===========================
# PRODUCTION ENVIRONMENT
# ===========================
PROD_DB_CONNECTION_STRING=Host=prod-db.internal;Port=5432;Database=ShieldReportDbProd;Username=postgres;Password=prod-password
PROD_JWT_SECRET_KEY=production-super-secret-key-must-be-at-least-32-characters-long
PROD_JWT_ISSUER=ShieldReport
PROD_JWT_AUDIENCE=ShieldReport.Client
PROD_SMTP_HOST=smtp.mailserver.prod
PROD_SMTP_PORT=587
PROD_SMTP_USERNAME=prod-smtp-user
PROD_SMTP_PASSWORD=prod-smtp-password
PROD_SMTP_FROM_ADDRESS=no-reply@project.local

# ===========================
# GITLAB CI/CD
# ===========================
CI_REGISTRY_USER=your-gitlab-username
CI_REGISTRY_PASSWORD=your-gitlab-token-or-password
