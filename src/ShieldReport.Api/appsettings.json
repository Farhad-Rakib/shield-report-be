{
  "DataAccess": {
    "Orm": "efcore"
  },
  "Database": {
    "Provider": "sqlserver"
  },
  "ConnectionStrings": {
    "PostgresConnection": "Host=localhost;Port=5432;Database=ShieldReportDb;Username=postgres;Password=postgres",
    "SqlServerConnection": "Server=localhost,1433;Database=ShieldReportDb;User Id=sa;Password=Mssql@12345Strong;TrustServerCertificate=True;"
  },
  "Caching": {
    "PermissionsTtlMinutes": 30,
    "MenusTtlMinutes": 30,
    "RolesTtlMinutes": 30,
    "RolePermissionsTtlMinutes": 30
  },
  "Jwt": {
    "Issuer": "ShieldReport",
    "Audience": "ShieldReport.Client",
    "SecretKey": "CHANGE_THIS_TO_A_STRONG_SECRET_KEY_WITH_AT_LEAST_32_CHARACTERS",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Smtp": {
    "Host": "smtp.mailserver.local",
    "Port": 587,
    "Username": "smtp-user",
    "Password": "smtp-password",
    "FromAddress": "no-reply@project.local",
    "FromName": "ShieldReport",
    "UseSsl": true
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "ShieldReport.Api"
    },
    "EnableSeq": false,
    "SeqServerUrl": "http://localhost:5341"
  },
  "AllowedHosts": "*"
}
