{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning"
    },
    "EnableSeq": false
  },
  "ConnectionStrings": {
    "PostgresConnection": "${DB_CONNECTION_STRING}"
  },
  "Jwt": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Smtp": {
    "Host": "${SMTP_HOST}",
    "Port": "${SMTP_PORT}",
    "Username": "${SMTP_USERNAME}",
    "Password": "${SMTP_PASSWORD}",
    "FromAddress": "${SMTP_FROM_ADDRESS}",
    "UseSsl": true
  },
  "AppSettings": {
    "Environment": "Production",
    "EnableSwagger": false,
    "LogLevel": "Warning"
  }
}
