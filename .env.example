# Copy this file to .env and fill in SERVER_IP before running `docker compose up --build`.
# .env is loaded automatically by docker compose from the same directory as docker-compose.yml.
#
# NOTE: this compose file expects shield-report-fe to be cloned as a sibling directory next to
# this repo (see docker-compose.yml's fe.build.context: ../shield-report-fe).

# REQUIRED: the LAN IP address of the machine running docker compose (NOT localhost/127.0.0.1) —
# this is what you'll send to teammates, and it's what their browsers use to reach the API/SignalR
# hub, so it must be reachable from their machines. Find it with `ipconfig getifaddr en0` (Wi-Fi on
# macOS) or `hostname -I` (Linux).
SERVER_IP=192.168.1.50

# Ports exposed on the host. Change only if they collide with something already running.
# (Port 5000 is avoided by default — macOS's AirPlay Receiver/ControlCenter binds it out of the box.)
FE_PORT=8080
API_PORT=5050

# SQL Server "sa" password. Must satisfy SQL Server's complexity policy (8+ chars, upper+lower+digit+symbol).
MSSQL_SA_PASSWORD=Str0ng!DemoPass2026

# JWT signing key — must be at least 32 characters. Any value is fine for an internal demo,
# just don't reuse a real production secret.
JWT_SECRET_KEY=shield-report-lan-demo-signing-key-change-me-2026

# Production (default) hides Swagger/Hangfire dashboard. Set to Development to expose them
# at http://<SERVER_IP>:<API_PORT>/swagger and /hangfire for reviewers who want to poke the API.
ASPNETCORE_ENVIRONMENT=Production
